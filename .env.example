# Copy this file to .env and fill values.
# .env is gitignored (never commit secrets).

# === Core Django ===
# Generate via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-50-char-random-secret

# True for dev, False for prod
DEBUG=True

# Comma-separated. For dev: localhost. For prod: yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# Dev (sqlite): leave blank — defaults to db.sqlite3
# Dev (docker postgres): postgres://iwallet:iwallet_dev@localhost:5432/iwallet
# Prod (local postgres on droplet): postgres://iwallet:STRONG-PASS@localhost:5432/iwallet
DATABASE_URL=

# === External services ===
# Get from @BotFather
TELEGRAM_BOT_TOKEN=
# Random secret for Telegram webhook URL path — also sent via Telegram's
# X-Telegram-Bot-Api-Secret-Token header when configured via setWebhook.
TELEGRAM_WEBHOOK_SECRET=
# Public origin where Telegram POSTs updates. Combined with the secret above
# to build the full webhook URL when `python manage.py setup_bot` runs.
# Example: https://iwallet.example.com  (no trailing slash, no path)
WEBHOOK_BASE_URL=
# Public WebApp landing URL — used by /start and `set_menu_button` for the
# inline WebApp button. Defaults to the prod URL if unset.
WEBAPP_URL=
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === Celery / Redis ===
# Dev: DB 0. Prod (shared droplet): DB 1 to avoid clashing with another project's Redis.
REDIS_URL=redis://localhost:6379/0

# === Logging ===
# Dev: console. Prod: json
LOG_LEVEL=INFO
