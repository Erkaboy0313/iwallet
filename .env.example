# Copy this file to .env and fill values.
# .env is gitignored (never commit secrets).

# === Core Django ===
# Generate via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-50-char-random-secret

# True for dev, False for prod
DEBUG=True

# Comma-separated. For dev: localhost. For prod: yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# Dev (sqlite): leave blank — defaults to db.sqlite3
# Dev (docker postgres): postgres://iwallet:iwallet_dev@localhost:5432/iwallet
# Prod (local postgres on droplet): postgres://iwallet:STRONG-PASS@localhost:5432/iwallet
DATABASE_URL=

# === External services ===
# Get from @BotFather
TELEGRAM_BOT_TOKEN=
# Random secret for Telegram webhook URL path
TELEGRAM_WEBHOOK_SECRET=
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === Celery / Redis ===
# Dev: DB 0. Prod (shared droplet): DB 1 to avoid clashing with another project's Redis.
REDIS_URL=redis://localhost:6379/0

# === Logging ===
# Dev: console. Prod: json
LOG_LEVEL=INFO
