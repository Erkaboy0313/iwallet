[Unit]
Description=IWALLET Celery Beat scheduler
After=network.target redis.service iwallet-celery-worker.service
Wants=redis.service

[Service]
Type=simple
User=iwallet
Group=iwallet
WorkingDirectory=/srv/iwallet/current
EnvironmentFile=/srv/iwallet/shared/.env
ExecStart=/srv/iwallet/venv/bin/celery -A iwallet beat --loglevel=INFO
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=iwallet-celery-beat

[Install]
WantedBy=multi-user.target
